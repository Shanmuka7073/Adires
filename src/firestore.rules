rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shanmuka7073@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function getStoreOwnerId(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() &&
        storeExists(storeId) &&
        getStoreOwnerId(storeId) == request.auth.uid;
    }

    /* ======================
       ADMIN OVERRIDE
       ====================== */

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    /* ======================
       USERS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
    }

    /* ======================
       STORES
       ====================== */

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow write: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    /* ======================
       BOOKINGS (STRICT AUTH)
       ====================== */

    function isValidBooking() {
      return isSignedIn() // FIX: Strict Auth Required
      && request.resource.data.keys().hasAll([
        "storeId",
        "serviceName",
        "date",
        "time",
        "userId"
      ])
      && storeExists(request.resource.data.storeId)
      && request.resource.data.userId == request.auth.uid;
    }

    match /bookings/{bookingId} {
      // Users can list their own or owners can list their store's
      allow list: if isSignedIn();
      
      // Detailed check for specific doc
      allow get: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        isStoreOwner(resource.data.storeId)
      );

      allow create: if isValidBooking();

      allow update: if isStoreOwner(resource.data.storeId) || isOwner(resource.data.userId);

      allow delete: if isAdmin();
    }

    /* ======================
       ORDERS (STRICT AUTH)
       ====================== */

    function isValidOrder() {
      return isSignedIn() // FIX: Strict Auth Required
      && request.resource.data.keys().hasAll([
        "storeId",
        "items",
        "totalAmount",
        "orderDate",
        "userId"
      ])
      && storeExists(request.resource.data.storeId)
      && request.resource.data.items.size() > 0
      && request.resource.data.totalAmount > 0
      && request.resource.data.userId == request.auth.uid;
    }

    match /orders/{orderId} {
      allow get, list: if isSignedIn();
      allow create: if isValidOrder();
      allow update: if isStoreOwner(resource.data.storeId) || isOwner(resource.data.userId);
    }

    /* ======================
       OTHER COLLECTIONS
       ====================== */

    match /employeeProfiles/{employeeId} {
      allow get, update: if isOwner(employeeId) || isStoreOwner(resource.data.storeId);
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow create: if isOwner(partnerId);
    }

    match /siteConfig/{configId} {
      allow read: if true;
    }

    match /canonicalCatalog/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /diagnostic_logs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}