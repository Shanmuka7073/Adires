rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shanmuka7073@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function getStoreOwnerId(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() &&
        storeExists(storeId) &&
        getStoreOwnerId(storeId) == request.auth.uid;
    }

    /* ======================
       ADMIN OVERRIDE
       ====================== */

    match /{document=**} {
      allow read, write: if isAdmin();
    }

    /* ======================
       USERS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
    }

    /* ======================
       STORES
       ====================== */

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow write: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    /* ======================
       BOOKINGS (FINAL FIX)
       ====================== */

    function isValidBooking() {
      return request.resource.data.keys().hasAll([
        "storeId",
        "service",
        "date",
        "time",
        "sessionId",
        "userId"
      ])
      && storeExists(request.resource.data.storeId)
      && (
        request.resource.data.userId == "guest" ||
        (isSignedIn() && request.resource.data.userId == request.auth.uid)
      );
    }

    match /bookings/{bookingId} {
      // Allow listing for signed in users (filtered by UI) and store owners
      allow list: if isSignedIn();
      
      // Owners can read their store's bookings
      allow get: if isStoreOwner(resource.data.storeId);
      
      // Users can read their own bookings
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.deviceId == request.auth.uid);

      // Create allowed for guests or signed in users
      allow create: if isValidBooking();

      // Updates restricted to creators or store owners
      allow update: if isStoreOwner(resource.data.storeId) || (isSignedIn() && resource.data.userId == request.auth.uid);

      allow delete: if isAdmin();
    }

    /* ======================
       ORDERS
       ====================== */

    function isValidOrder() {
      return (
        request.resource.data.keys().hasAll([
          "storeId",
          "items",
          "totalAmount",
          "orderDate",
          "sessionId"
        ])
        && storeExists(request.resource.data.storeId)
        && request.resource.data.items.size() > 0
        && request.resource.data.totalAmount > 0
        && (
          request.resource.data.userId == "guest" ||
          (isSignedIn() && request.resource.data.userId == request.auth.uid)
        )
      );
    }

    match /orders/{orderId} {
      allow get, list: if true;
      allow create: if isValidOrder();
      allow update: if isStoreOwner(resource.data.storeId)
        || (isSignedIn() && resource.data.userId == request.auth.uid)
        || (resource.data.userId == 'guest' && request.resource.data.sessionId == resource.data.sessionId);
    }

    /* ======================
       OTHER COLLECTIONS
       ====================== */

    match /employeeProfiles/{employeeId} {
      allow get, update: if isOwner(employeeId) || isStoreOwner(resource.data.storeId);
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow create: if isOwner(partnerId);
    }

    match /siteConfig/{configId} {
      allow read: if true;
    }

    match /canonicalCatalog/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /diagnostic_logs/{logId} {
      allow read, write: if isSignedIn();
    }

    match /voiceAliasGroups/{key} {
      allow read: if true;
    }

    match /voiceCommands/{commandKey} {
      allow read: if true;
    }
  }
}