
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description System Admin check.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shanmuka7073@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function isStoreOwner(storeId) {
      return isSignedIn() &&
        storeExists(storeId) &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /* ======================
       COLLECTIONS
       ====================== */

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStoreOwner(storeId);

      match /products/{productId} {
        allow get, list: if true;
        allow write: if isStoreOwner(storeId);
      }
      
      match /menus/{menuId} {
        allow read: if true;
        allow write: if isStoreOwner(storeId);
      }

      match /attendance/{recordId} {
        allow read, write: if isSignedIn();
      }

      match /salarySlips/{slipId} {
        allow read, write: if isSignedIn();
      }
    }

    match /orders/{orderId} {
      allow read: if true; 
      allow create: if isSignedIn() || request.resource.data.userId == 'guest';
      allow update: if isSignedIn();
    }

    match /bookings/{bookingId} {
      allow read, write: if isSignedIn();
    }

    match /chats/{chatId} {
      allow list: if isSignedIn();
      allow get, update: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /calls/{callId} {
      allow read, write: if isSignedIn();
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    match /deliveryPartners/{partnerId} {
      allow get, update, create: if isOwner(partnerId);
    }

    match /diagnostic_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    
    match /failedCommands/{commandId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    match /voiceAliasGroups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /canonicalCatalog/{productId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    /* ======================
       ADMIN OVERRIDE (GLOBAL)
       ===================== */
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
