rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    /**
     * @description System Admin check.
     * Triggers rule redeploy on comment change.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shanmuka7073@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function isStoreOwner(storeId) {
      return isSignedIn() &&
        storeExists(storeId) &&
        get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId == request.auth.uid;
    }

    /* ======================
       GLOBAL CONFIG (PUBLIC READ)
       ====================== */
    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    /* ======================
       ADMIN OVERRIDE (GLOBAL)
       ===================== */
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    /* ======================
       CALLS & SIGNALING (RECURSIVE)
       ====================== */
    
    match /calls/{callId} {
      allow read, write: if isSignedIn();
      
      match /{allPaths=**} {
        allow read, write: if isSignedIn();
      }
    }

    /* ======================
       CHATS & MESSAGES
       ====================== */
    
    match /chats/{chatId} {
      allow list: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow get: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && request.auth.uid in resource.data.participants;

      match /messages/{messageId} {
        allow read, write: if isSignedIn() &&
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    /* ======================
       COLLECTIONS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow write: if isStoreOwner(storeId);
    }
    
    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    match /orders/{orderId} {
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /bookings/{bookingId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow create: if isOwner(partnerId);
    }

    match /diagnostic_logs/{logId} {
      allow read, write: if isSignedIn();
    }
    
    match /failedCommands/{commandId} {
      allow create: if true;
      allow read, write: if isAdmin();
    }
    
    match /voiceAliasGroups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}