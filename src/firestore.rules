
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.email == 'shanmuka7073@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function getStoreOwnerId(storeId) {
        return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && (
        (storeExists(storeId) && getStoreOwnerId(storeId) == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid) ||
        (resource != null && resource.data.ownerId == request.auth.uid)
      );
    }

    /* ======================
       ORDER VALIDATION (SAFE GUEST SUPPORT)
       ====================== */

    function isValidOrder() {
      return (
        request.resource.data.keys().hasAll([
          "storeId",
          "items",
          "totalAmount",
          "orderDate",
          "sessionId"
        ])
        && storeExists(request.resource.data.storeId)
        && request.resource.data.items.size() > 0
        && request.resource.data.totalAmount > 0
        && (
          request.resource.data.userId == "guest" ||
          (isSignedIn() && request.resource.data.userId == request.auth.uid)
        )
      );
    }

    /* ======================
       COLLECTIONS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStoreOwner(storeId) || isAdmin();
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow write: if isStoreOwner(storeId) || isAdmin();
    }
    
    // Admin Global Product Audit
    match /{path=**}/products/{productId} {
      allow read, list: if isAdmin();
    }

    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    match /orders/{orderId} {
      allow get, list: if true;
      allow create: if isValidOrder();
      allow update: if isStoreOwner(resource.data.storeId) || resource.data.userId == request.auth.uid || (resource.data.userId == 'guest' && request.resource.data.sessionId == resource.data.sessionId);
    }

    match /voiceAliasGroups/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /voiceCommands/{commandKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /employeeProfiles/{employeeId} {
      allow get, update: if isOwner(employeeId) || isStoreOwner(resource.data.storeId);
      allow create, delete, list: if isAdmin();
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow list: if isAdmin();
      allow create: if isOwner(partnerId);
    }
  }
}
