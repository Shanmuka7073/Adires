
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shanmuka7073@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function getStoreOwnerId(storeId) {
        return storeExists(storeId) 
          ? get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId 
          : null;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && (
        (storeExists(storeId) && getStoreOwnerId(storeId) == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid) ||
        (resource != null && resource.data.ownerId == request.auth.uid)
      );
    }

    /* ======================
       ADMIN OVERRIDE (GLOBAL)
       ====================== */
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    /* ======================
       COLLECTIONS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow write: if isStoreOwner(storeId);
    }
    
    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    match /orders/{orderId} {
      // Allow read for session tracking (denied for non-filtered list by engine)
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isStoreOwner(resource.data.storeId) || resource.data.userId == request.auth.uid;
    }

    match /bookings/{bookingId} {
        // ALLOW PUBLIC READ (Needed for Guest Session Counts & Merchant Dashboards)
        // Note: Filtered queries (where storeId == X) are safe and don't leak global data.
        allow read: if true;
        // Signup required for all modifications
        allow create: if isSignedIn(); 
        allow update: if isStoreOwner(resource.data.storeId) || resource.data.userId == request.auth.uid;
    }

    match /voiceAliasGroups/{key} {
      allow read: if true;
    }
    
    match /voiceCommands/{commandKey} {
      allow read: if true;
    }

    match /siteConfig/{configId} {
      allow read: if true;
    }

    match /employeeProfiles/{employeeId} {
      allow get, update: if isOwner(employeeId) || isStoreOwner(resource.data.storeId);
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow create: if isOwner(partnerId);
    }

    match /canonicalCatalog/{productId} {
      allow read: if true;
      allow write: if isSignedIn(); 
    }
    
    match /diagnostic_logs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
