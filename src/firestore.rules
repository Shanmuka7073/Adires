

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getStoreOwnerId(storeId) {
      return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && getStoreOwnerId(storeId) == request.auth.uid;
    }
    
    function isManager(employeeId, storeId) {
       let employeeProfile = get(/databases/$(database)/documents/employeeProfiles/$(employeeId)).data;
       return employeeProfile.reportingTo == request.auth.uid || isStoreOwner(storeId);
    }
    

    /* ======================
       USERS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow list: if false; // List should be restricted

      allow create: if
        // User creating their own account
        (isOwner(userId) && request.resource.data.id == userId)
        // Store owner creating employee user
        || (
          request.resource.data.accountType == 'employee'
          && isStoreOwner(request.resource.data.storeId)
        );
    }

    /* ======================
       STORES / RESTAURANTS
       ====================== */

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    /* ======================
       EMPLOYEE PROFILES
       ====================== */

    match /employeeProfiles/{employeeId} {
      allow get, update: if
        isOwner(employeeId)
        || isStoreOwner(resource.data.storeId);
      
      // Only store owners can create/delete profiles
      allow create, delete: if
        isStoreOwner(request.resource.data.storeId);
      
      allow list: if isStoreOwner(resource.data.storeId);
    }


    /* ======================
       ATTENDANCE
       ====================== */

    match /stores/{storeId}/attendance/{recordId} {
      allow list: if isStoreOwner(storeId);
      allow get: if isStoreOwner(storeId) || isOwner(resource.data.employeeId);
      
      allow create: if
        isOwner(request.resource.data.employeeId)
        && request.resource.data.storeId == storeId;

      allow update: if
        // Employee punching out
        (isOwner(resource.data.employeeId) && resource.data.punchOutTime == null && request.resource.data.punchOutTime != null) ||
        // Employee requesting regularization
        (isOwner(resource.data.employeeId) && (resource.data.status == 'partially_present' || resource.data.status == 'rejected')) ||
        // Manager or Store Owner approving/rejecting
        (isManager(resource.data.employeeId, storeId));
        
      allow delete: if false;
    }
    
    match /{path=**}/attendance/{recordId} {
       allow read: if request.auth != null && resource.data.employeeId == request.auth.uid;
    }


    /* ======================
       SALARY SLIPS
       ====================== */

    match /stores/{storeId}/salarySlips/{slipId} {

      allow get: if
        isStoreOwner(storeId)
        || isOwner(resource.data.employeeId);

      allow list: if 
        isStoreOwner(storeId) 
        || (request.auth != null && request.query.where[0][2] == request.auth.uid);

      allow create, update, delete: if isStoreOwner(storeId);
    }
    
     match /{path=**}/salarySlips/{slipId} {
       allow get: if isSignedIn();
    }


    /* ======================
       ORDERS (GROCERY / RESTAURANT)
       ====================== */

    match /orders/{orderId} {
      allow get, list: if true;

      allow create: if
        (isSignedIn() && request.resource.data.userId == request.auth.uid)
        || (
          request.resource.data.userId == 'guest'
          && request.resource.data.storeId is string
          && request.resource.data.sessionId is string
        );

      allow update: if
        isStoreOwner(resource.data.storeId)
        || (resource.data.userId != 'guest' && request.auth.uid == resource.data.userId && request.resource.data.status == 'Billed')
        || (resource.data.deliveryPartnerId != null && request.auth.uid == resource.data.deliveryPartnerId)
        || (resource.data.userId == 'guest' && request.resource.data.sessionId == resource.data.sessionId)
        || (resource.data.deliveryPartnerId == null && request.resource.data.deliveryPartnerId == request.auth.uid);

      allow delete: if false;
    }
    
    match /orders/{orderId}/orderItems/{orderItemId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /* ======================
       OTHER COLLECTIONS
       ====================== */
       
    match /asha-conversations/{userId}/{document=**} { allow read, write: if isSignedIn(); }
    match /asha-conversations/{userId}/atlas_reports/{reportId} { allow create, read: if isOwner(userId); }
    match /users/{userId}/productRecommendations/{recId} { allow get, list: if isOwner(userId); allow create, update, delete: if false; }
    match /voice-orders/{voiceOrderId} { allow read, write: if isSignedIn(); }
    match /cachedRecipes/{recipeId} { allow get, list: if true; allow create, update: if isSignedIn(); allow delete: if false; }
    match /cachedAIResponses/{responseId} { allow get, list: if true; allow create: if true; allow update, delete: if false; }
    match /deliveryPartners/{partnerId} { allow get, update: if isOwner(partnerId); allow list: if false; allow create: if isOwner(partnerId) && request.resource.data.userId == partnerId; allow delete: if false; }
    match /deliveryPartners/{partnerId}/payouts/{payoutId} { allow get, list: if isOwner(partnerId); allow create: if isOwner(partnerId); allow update, delete: if false; }
    match /productPrices/{productName} { allow get, list: if true; allow write: if false; }
    match /failedCommands/{commandId} { allow read, list: if false; allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid; allow update, delete: if false; }
    match /voiceAliasGroups/{key} { allow read: if true; allow write: if false; }
    match /voiceCommands/{commandKey} { allow read: if true; allow write: if false; }
    match /siteConfig/{configId} { allow read: if true; allow write: if false; }
    match /voiceprints/{userId} { allow read, write: if isOwner(userId); }
    match /nlu_extracted_sentences/{sentenceId} { allow read, write: if false; }
  }
}

    