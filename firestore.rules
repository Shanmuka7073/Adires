rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'shanmuka7073@gmail.com' ||
        request.auth.token.email == 'admin@gmail.com'
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function storeExists(storeId) {
      return exists(/databases/$(database)/documents/stores/$(storeId));
    }

    function getStoreOwnerId(storeId) {
        return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() &&
        storeExists(storeId) &&
        getStoreOwnerId(storeId) == request.auth.uid;
    }

    /* ======================
       ADMIN OVERRIDE (GLOBAL)
       ====================== */
    match /{document=**} {
      allow read, write: if isAdmin();
    }

    /* ======================
       CHATS & MESSAGES
       ====================== */
    
    match /chats/{chatId} {
      // Allow signed-in users to read chat metadata (inbox/lookup)
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        // Strict privacy: Only participants can read/write messages
        allow read, write: if isSignedIn() && 
          request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
      }
    }

    /* ======================
       COLLECTIONS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow create: if isSignedIn();
    }

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn();
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow write: if isStoreOwner(storeId);
    }
    
    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    match /orders/{orderId} {
      // Allow reading for session tracking and owner dashboard
      allow read: if true; 
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /bookings/{bookingId} {
      // Allow read for real-time slot/session tracking
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow create: if isOwner(partnerId);
    }

    match /siteConfig/{configId} {
      allow read: if true;
    }

    match /diagnostic_logs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}