
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.email == 'admin@gmail.com'
        || request.auth.token.email == 'admin2@gmail.com');
    }

    function isChickenAdmin() {
      return isSignedIn() &&
        request.auth.token.email == 'chickenadmin@gmail.com';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getStoreOwnerId(storeId) {
        return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && getStoreOwnerId(storeId) == request.auth.uid;
    }
    
    function isManager(employeeId, storeId) {
       let employeeProfile = get(/databases/$(database)/documents/employeeProfiles/$(employeeId)).data;
       return employeeProfile.reportingTo == request.auth.uid || isStoreOwner(storeId);
    }

    /* ======================
       USERS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId);
      allow list: if isAdmin();

      allow create: if
        // User creating their own account
        (isOwner(userId) && request.resource.data.id == userId)
        // Admin
        || isAdmin()
        // Store owner creating employee user
        || (
          request.resource.data.accountType == 'employee'
          && isStoreOwner(request.resource.data.storeId)
        );
    }

    /* ======================
       STORES / RESTAURANTS
       ====================== */

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if
        (isSignedIn() && request.resource.data.ownerId == request.auth.uid)
        || isAdmin();
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow create, update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/packages/{packageId} {
      allow get, list: if true;
      allow create, update, delete: if isStoreOwner(storeId);
    }

    /* ======================
       EMPLOYEE PROFILES
       ====================== */

    match /employeeProfiles/{employeeId} {

      allow get, update: if
        isOwner(employeeId)
        || isStoreOwner(resource.data.storeId);

      allow create, delete: if
        isStoreOwner(request.resource.data.storeId)
        || isAdmin();

      allow list: if
        isStoreOwner(resource.data.storeId)
        || isAdmin();
    }

    /* ======================
       SALARY SLIPS
       ====================== */

    match /stores/{storeId}/salarySlips/{slipId} {

      allow get: if
        isStoreOwner(storeId)
        || isOwner(resource.data.employeeId);

      allow list: if 
        isStoreOwner(storeId); 

      allow create, update, delete: if isStoreOwner(storeId);
    }
    
     // SAFE collectionGroup rule for salary slips
     match /{path=**}/salarySlips/{slipId} {
       allow get: if
        isStoreOwner(resource.data.storeId)
        || resource.data.employeeId == request.auth.uid;
       allow list: if isStoreOwner(resource.data.storeId);
    }

    /* ======================
       ATTENDANCE (FINAL)
       ====================== */
    
    match /stores/{storeId}/attendance/{recordId} {
        
      // READ single doc
      allow get: if
        isSignedIn() &&
        (
          // employee can read own record
          resource.data.employeeId == request.auth.uid
          ||
          // store owner can read any record of their store
          isStoreOwner(storeId)
          ||
          // manager can read their employees
          isManager(resource.data.employeeId, storeId)
        );

      // LIST / QUERY (collection, NOT collectionGroup)
      allow list: if
        isSignedIn() &&
        (
          isStoreOwner(storeId)
          || request.query.where('employeeId', '==', request.auth.uid)
        );
        
      allow create: if
        isSignedIn() &&
        request.resource.data.employeeId == request.auth.uid &&
        request.resource.data.storeId == storeId;

      allow update: if
        isSignedIn() &&
        (
          isManager(resource.data.employeeId, storeId)
          || (
            resource.data.employeeId == request.auth.uid &&
            resource.data.punchOutTime == null
          )
        );

      allow delete: if false;
    }


    /* ======================
       ORDERS (GROCERY / RESTAURANT)
       ====================== */

    match /orders/{orderId} {
      allow get, list: if true;

      allow create: if
        (isSignedIn() && request.resource.data.userId == request.auth.uid)
        || (
          request.resource.data.userId == 'guest'
          && request.resource.data.storeId is string
          && request.resource.data.sessionId is string
        );

      allow update: if
        isStoreOwner(resource.data.storeId)
        || (resource.data.userId != 'guest' && request.auth.uid == resource.data.userId && request.resource.data.status == 'Billed')
        || (resource.data.deliveryPartnerId != null && request.auth.uid == resource.data.deliveryPartnerId)
        || (resource.data.userId == 'guest' && request.resource.data.sessionId == resource.data.sessionId)
        || (resource.data.deliveryPartnerId == null && request.resource.data.deliveryPartnerId == request.auth.uid);

      allow delete: if false;
    }
    
    // SAFE collectionGroup rule for orders
    match /{path=**}/orders/{orderId} {
        allow get: if true;
        allow list: if 
            request.query.where('storeId', '==', resource.data.storeId)
            || request.query.where('userId', '==', request.auth.uid);
    }
    
    match /orders/{orderId}/orderItems/{orderItemId} {
      allow get, list: if true;
      allow create, update, delete: if false;
    }

    /* ======================
       CONFIG & MISC
       ====================== */
    match /asha-conversations/{userId}/{document=**} {
        allow read, write: if isSignedIn();
    }
     
    match /asha-conversations/{userId}/atlas_reports/{reportId} {
      allow create, read: if isOwner(userId);
    }

    match /users/{userId}/productRecommendations/{productRecommendationId} {
      allow get, list: if isOwner(userId);
      allow create, update, delete: if false;
    }
    
    match /voice-orders/{voiceOrderId} {
      allow read, write: if isSignedIn();
    }
    
    match /cachedRecipes/{recipeId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
      allow delete: if false;
    }

    match /cachedAIResponses/{responseId} {
        allow get, list: if true;
        allow create: if true;
        allow update, delete: if false;
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow list: if isAdmin();
      allow create: if isOwner(partnerId) && request.resource.data.userId == partnerId;
      allow delete: if false;
    }

    match /deliveryPartners/{partnerId}/payouts/{payoutId} {
      allow get, list: if isOwner(partnerId);
      allow create: if isOwner(partnerId);
      allow update, delete: if false;
    }

    match /productPrices/{productName} {
      allow get, list: if true;
      allow write: if isAdmin()
        || (isChickenAdmin() && productName.matches('.*chicken.*'));
    }
    
    match /failedCommands/{commandId} {
      allow read, list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /voiceAliasGroups/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    match /voiceCommands/{commandKey} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
     match /voiceprints/{userId} {
        allow read, write: if isOwner(userId);
     }
     
     match /nlu_extracted_sentences/{sentenceId} {
      allow read, write: if isAdmin();
    }
  }
}
