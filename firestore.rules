
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /* ======================
       COMMON HELPER FUNCTIONS
       ====================== */

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        (request.auth.token.email == 'admin@gmail.com'
        || request.auth.token.email == 'admin2@gmail.com');
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function getStoreOwnerId(storeId) {
        return get(/databases/$(database)/documents/stores/$(storeId)).data.ownerId;
    }

    function isStoreOwner(storeId) {
      return isSignedIn() && (
        (exists(/databases/$(database)/documents/stores/$(storeId)) && getStoreOwnerId(storeId) == request.auth.uid) ||
        (request.resource != null && request.resource.data.ownerId == request.auth.uid)
      );
    }
    
    function isManager(employeeId, storeId) {
       let employeeProfile = get(/databases/$(database)/documents/employeeProfiles/$(employeeId)).data;
       return employeeProfile.reportingTo == request.auth.uid || isStoreOwner(storeId);
    }

    /* ======================
       USERS
       ====================== */

    match /users/{userId} {
      allow get, update, delete: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn();
    }

    /* ======================
       STORES / RESTAURANTS
       ====================== */

    match /stores/{storeId} {
      allow get, list: if true;
      allow create: if isSignedIn() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if 
        resource.data.ownerId == request.auth.uid || 
        isAdmin();
    }

    match /stores/{storeId}/products/{productId} {
      allow get, list: if true;
      allow create: if isSignedIn() && isStoreOwner(storeId);
      allow update, delete: if isStoreOwner(storeId);
    }

    match /stores/{storeId}/menus/{menuId} {
      allow read: if true;
      allow write: if isSignedIn() && isStoreOwner(storeId);
    }

    match /stores/{storeId}/packages/{packageId} {
      allow get, list: if true;
      allow create, update, delete: if isStoreOwner(storeId);
    }

    /* ======================
       EMPLOYEE PROFILES
       ====================== */

    match /employeeProfiles/{employeeId} {
      allow get, update: if isOwner(employeeId) || isStoreOwner(resource.data.storeId);
      allow create, delete: if isStoreOwner(request.resource.data.storeId) || isAdmin();
      allow list: if isStoreOwner(resource.data.storeId) || isAdmin();
    }

    /* ======================
       ATTENDANCE
       ====================== */

    match /stores/{storeId}/attendance/{recordId} {
      allow get, list: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isStoreOwner(storeId));
      allow create: if isSignedIn() && request.resource.data.employeeId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.employeeId == request.auth.uid || isStoreOwner(storeId));
    }

    /* ======================
       ORDERS
       ====================== */

    match /orders/{orderId} {
      allow get, list: if true;
      allow create: if isSignedIn() || request.resource.data.userId == 'guest';
      allow update: if isStoreOwner(resource.data.storeId) || resource.data.userId == request.auth.uid || resource.data.deliveryPartnerId == request.auth.uid;
    }

    /* ======================
       CONFIG & MISC
       ====================== */
    match /cachedRecipes/{recipeId} {
      allow get, list: if true;
      allow create, update: if isSignedIn();
    }

    match /deliveryPartners/{partnerId} {
      allow get, update: if isOwner(partnerId);
      allow list: if isAdmin();
      allow create: if isOwner(partnerId);
    }

    match /siteConfig/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /diagnostic_logs/{logId} {
      allow read, write: if isSignedIn();
    }
  }
}
