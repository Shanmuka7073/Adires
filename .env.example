
# ------------------------------------------------------------------
# Firebase Admin SDK Configuration (for Server-Side functions)
# ------------------------------------------------------------------
# These variables are used by src/firebase/admin-init.ts to authenticate
# server-side requests. Copy the values from your service account JSON file.
# IMPORTANT: The private key must be wrapped in double quotes.

FIREBASE_PROJECT_ID="your-project-id"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYourPrivateKeyLine1\nYourPrivateKeyLine2\n-----END PRIVATE KEY-----\n"

# ------------------------------------------------------------------
# Firebase Client SDK Configuration (for Browser/Client-Side)
# ------------------------------------------------------------------
# These variables are used by src/firebase/config.ts to initialize
# Firebase in the user's browser. They are public by design.

NEXT_PUBLIC_FIREBASE_API_KEY="AIza..."
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN="your-project-id.firebaseapp.com"
NEXT_PUBLIC_FIREBASE_PROJECT_ID="your-project-id"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET="your-project-id.appspot.com"
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID="1234567890"
NEXT_PUBLIC_FIREBASE_APP_ID="1:12345:web:abcdef"
NEXT_PUBLIC_FIREBASE_VAPID_KEY="Your_VAPID_Key_For_Push_Notifications"
