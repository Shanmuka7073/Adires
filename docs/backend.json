
{
  "entities": {
    "Store": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Store",
      "type": "object",
      "description": "Represents a local store that lists products on LocalBasket.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "teluguName": { "type": "string" },
        "description": { "type": "string" },
        "address": { "type": "string" },
        "ownerId": { "type": "string" },
        "imageId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "isClosed": { "type": "boolean" },
        "tables": { "type": "array", "items": { "type": "string" } },
        "liveVideoUrl": { "type": "string", "format": "uri" },
        "upiId": { "type": "string" }
      },
      "required": ["id", "name", "description", "address", "ownerId", "imageId", "latitude", "longitude"]
    },
    "Product": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Product",
      "type": "object",
      "description": "Represents a product listed by a store.",
      "properties": {
        "id": { "type": "string" },
        "storeId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "imageId": { "type": "string" },
        "imageUrl": { "type": "string" },
        "imageHint": { "type": "string" }
      },
      "required": ["id", "storeId", "name", "imageId"]
    },
    "User": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "User",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "address": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "accountType": { "type": "string", "enum": ["groceries", "restaurant", "employee"] },
        "imageUrl": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "fcmToken": { "type": "string" }
      },
      "required": ["id", "firstName", "lastName", "email", "address", "phoneNumber"]
    },
    "ErrorLog": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ErrorLog",
      "type": "object",
      "description": "Captured runtime system errors.",
      "properties": {
        "id": { "type": "string" },
        "message": { "type": "string" },
        "stack": { "type": "string" },
        "url": { "type": "string" },
        "userId": { "type": "string" },
        "accountType": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["message", "url", "timestamp"]
    },
    "Order": {
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "storeId": { "type": "string" },
        "status": { "type": "string" },
        "totalAmount": { "type": "number" },
        "orderDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "storeId", "orderDate", "totalAmount", "status"]
    }
  },
  "auth": { "providers": ["password"] },
  "firestore": {
    "structure": [
      { "path": "/users/{userId}", "definition": { "entityName": "User", "schema": { "$ref": "#/backend/entities/User" } } },
      { "path": "/stores/{storeId}", "definition": { "entityName": "Store", "schema": { "$ref": "#/backend/entities/Store" } } },
      { "path": "/error_logs/{logId}", "definition": { "entityName": "ErrorLog", "schema": { "$ref": "#/backend/entities/ErrorLog" } } }
    ]
  }
}
